# ─────────────────────────────────────────────────────────────────────────────
# Secure File Upload — Environment Variables
# Copy this file to /.env at the monorepo root and fill in your values.
# NEVER commit the .env file — it is blocked by .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=secure_upload
DB_USER=postgres
DB_PASSWORD=your_password_here

# Connection pool
DB_POOL_MIN=2
DB_POOL_MAX=10

# ── JWT ───────────────────────────────────────────────────────────────────────
# CHANGE BOTH SECRETS IN PRODUCTION — use long random strings (min 64 chars)
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=dev-access-secret-change-in-production
JWT_REFRESH_SECRET=dev-refresh-secret-change-in-production

# Token expiry (optional — defaults shown)
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ── Authentication policy ─────────────────────────────────────────────────────
BCRYPT_COST=12             # bcrypt cost factor — increase for more security (slower)
MAX_LOGIN_ATTEMPTS=5       # lock account after N consecutive failures
LOCK_DURATION_MS=1800000   # lockout duration in ms (default: 30 minutes)

# ── API server ────────────────────────────────────────────────────────────────
API_PORT=3000
NODE_ENV=development

# ── Rate limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000   # 15 minutes in ms
RATE_LIMIT_MAX=20             # max upload requests per window per IP

# ── Signed download URLs ──────────────────────────────────────────────────────
# HMAC secret for signing download URLs — change in production
SIGNED_URL_SECRET=dev-signed-url-secret-change-in-production

# ── VirusTotal (Week 3) ───────────────────────────────────────────────────────
# Free tier: 500 requests/day, 4 requests/minute
# Get a free key at: https://www.virustotal.com/gui/sign-in
VIRUSTOTAL_API_KEY=

# ── File upload ───────────────────────────────────────────────────────────────
MAX_FILE_SIZE_BYTES=524288000   # 500 MB
ALLOWED_EXTENSIONS=pdf,doc,docx,xls,xlsx,ppt,pptx,txt,csv,zip,tar,gz,7z,png,jpg,jpeg,gif,mp4,mp3,wav
# QUARANTINE_DIR=/absolute/path/to/quarantine  # defaults to ./quarantine
