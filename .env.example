# Shared Package Environment Variables
# Copy this to /.env at the monorepo root and fill in your values

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=secure_upload
DB_USER=postgres
DB_PASSWORD=your_password_here

# Connection pool
DB_POOL_MIN=2
DB_POOL_MAX=10

# Node environment
NODE_ENV=development
