{
  "name": "@secure-upload/shared",
  "version": "1.0.0",
  "private": true,
  "description": "Shared DB connection, migrations, and utilities",
  "main": "src/index.js",
  "scripts": {
    "migrate": "knex --knexfile src/db/knexfile.js migrate:latest",
    "migrate:rollback": "knex --knexfile src/db/knexfile.js migrate:rollback",
    "migrate:status": "knex --knexfile src/db/knexfile.js migrate:status",
    "migrate:make": "knex --knexfile src/db/knexfile.js migrate:make"
  },
  "dependencies": {
    "bullmq": "^5.34.6",
    "dotenv": "^16.4.5",
    "ioredis": "^5.4.2",
    "knex": "^3.1.0",
    "pg": "^8.12.0",
    "uuid": "^10.0.0"
  }
}
