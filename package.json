{
  "name": "secure-file-upload-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "Secure file upload and malware scanning system",
  "workspaces": [
    "api",
    "scan-worker",
    "shared"
  ],
  "scripts": {
    "dev": "concurrently --names \"API,WORKER,FRONT\" --prefix-colors \"yellow.bold,cyan.bold,magenta.bold\" \"npm run dev:api\" \"npm run dev:worker\" \"npm run dev:front\"",
    "dev:api":    "node api/src/index.js",
    "dev:worker": "node scan-worker/src/index.js",
    "dev:front":  "npm run dev --prefix frontend",
    "docker:up":  "docker-compose up -d postgres redis clamav",
    "docker:down": "docker-compose down",
    "start": "npm run docker:up && npm run dev",
    "api":    "npm run dev --workspace=api",
    "worker": "npm run dev --workspace=scan-worker",
    "migrate": "npm run migrate --workspace=shared",
    "migrate:rollback": "npm run migrate:rollback --workspace=shared",
    "install:all": "npm install"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "concurrently": "^10.0.3",
    "socket.io-client": "^4.8.3"
  }
}
